{
  "name": "ledger-video-recorder",
  "version": "0.1.0",
  "description": "Loom-style screen + webcam recorder with a simple, premium editor",
  "main": "./out/main/index.js",
  "author": "Qin Tjokrosurjo",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "postinstall": "electron-builder install-app-deps",
    "pack": "npm run build && electron-builder --dir",
    "app:install": "npm run build && electron-builder --dir && rm -rf \"/Applications/Ledger Video Recorder.app\" && cp -R dist/mac*/*.app /Applications/ && open -R \"/Applications/Ledger Video Recorder.app\" && echo \"Installed to /Applications — launch it from Spotlight (Cmd+Space).\"",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "framer-motion": "^11.11.17",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^7.1.0"
  },
  "allowScripts": {
    "@ffmpeg-installer/darwin-arm64@4.1.5": true,
    "esbuild@0.25.12": true,
    "fsevents@2.3.3": true,
    "electron-winstaller@5.4.0": true,
    "electron@43.0.0": true
  }
}
